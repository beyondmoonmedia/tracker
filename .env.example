# Local Parse + Parse Dashboard (trackerserver.js)
# Dashboard UI: http://localhost:1337/dashboard
# Parse REST:   http://localhost:1337/parse

MONGODB_URI=mongodb://localhost:27017/dev
PARSE_APP_ID=myAppId
PARSE_MASTER_KEY=myMasterKey
PARSE_SERVER_URL=http://localhost:1337/parse
PORT=1337

# Ethereum / BSC RPC — public defaults are heavily rate-limited (429). Prefer provider URLs with an API key.
# ALCHEMY_API_KEY=...          # used for eth-mainnet if ETH_RPC_URL unset
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# BSC_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
# ETH_POLL_INTERVAL_MS=45000
# ETH_MAX_BLOCKS_PER_POLL=4
# ETH_RATE_LIMIT_PAUSE_MS=120000
# BSC_POLL_INTERVAL_MS=30000
# BSC_MAX_BLOCKS_PER_POLL=4
